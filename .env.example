# -------------------------------------------------------
# file-viewer — environment variables
# Copy this file to .env and fill in your values.
# -------------------------------------------------------

# Absolute path on the HOST machine to your documents folder.
# This directory will be mounted into the container at /app/documents.
DOCS_DIR=/path/to/your/documents

# Path for HTML cache (relative or absolute on host).
# Defaults to ./cache next to docker-compose.yml.
CACHE_DIR=./cache

# Days before cached HTML files are considered stale.
CACHE_EXPIRY_DAYS=30

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Port exposed on the host
APP_PORT=8070
